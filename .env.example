# Google Cloud Vision API клуч за препознавање на ракопис
# 1. Оди на: https://console.cloud.google.com/
# 2. Создај проект → APIs & Services → Enable "Cloud Vision API"
# 3. Credentials → Create API Key → копирај го клучот овде
# 4. Преименувај го овој фајл во ".env" (без .example)

VITE_GOOGLE_VISION_KEY=твојот_api_клуч_овде
