# ============================================================
# digitalPIRLS — Environment Variables
# Копирај го овој фајл во .env.local и пополни ги вредностите
# ============================================================

# ── Firebase Realtime Database (Командна Табла за Наставник) ──
# 1. Одди на: https://console.firebase.google.com/
# 2. Создади проект → Build → Realtime Database → Create database
# 3. Project Settings → Your apps → Add app (Web) → Copy config
VITE_FIREBASE_API_KEY=твојот_api_key_овде
VITE_FIREBASE_AUTH_DOMAIN=твојот-проект.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://твојот-проект-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=твојот-проект
VITE_FIREBASE_STORAGE_BUCKET=твојот-проект.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ── Наставник PIN (стандардно: pirls2025) ──
VITE_TEACHER_PIN=pirls2025
